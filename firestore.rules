rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasUser() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isCurrentSchool(schoolId) {
      return hasUser() && me().schoolId == schoolId;
    }

    function isHistoricalSchool(schoolId) {
      return hasUser()
        && me().role == 'pupil'
        && me().schoolHistoryIds is list
        && me().schoolHistoryIds.hasAny([schoolId]);
    }

    function canReadSchool(schoolId) {
      return isCurrentSchool(schoolId) || isHistoricalSchool(schoolId);
    }

    function isSchoolAdmin(schoolId) {
      return isCurrentSchool(schoolId) && me().role == 'schoolAdmin';
    }

    function isDepartmentHead(schoolId) {
      return isCurrentSchool(schoolId) && me().role == 'departmentHead';
    }

    function isTeacher(schoolId) {
      return isCurrentSchool(schoolId) && me().role == 'teacher';
    }

    function leadsDepartment(schoolId, departmentId) {
      return isDepartmentHead(schoolId)
        && me().departmentIds is list
        && me().departmentIds.hasAny([departmentId]);
    }

    function teachesClass(schoolId, classId) {
      return isTeacher(schoolId)
        && exists(/databases/$(database)/documents/schools/$(schoolId)/classes/$(classId))
        && get(/databases/$(database)/documents/schools/$(schoolId)/classes/$(classId)).data.teacherIds is list
        && get(/databases/$(database)/documents/schools/$(schoolId)/classes/$(classId)).data.teacherIds.hasAny([request.auth.uid]);
    }

    function isStaff(schoolId) {
      return isSchoolAdmin(schoolId) || isDepartmentHead(schoolId) || isTeacher(schoolId);
    }

    function ownsPupilRecord(data) {
      return signedIn() && data.pupilId == request.auth.uid;
    }

    function validInvite(schoolId, inviteCode, role) {
      return inviteCode is string
        && exists(/databases/$(database)/documents/schools/$(schoolId)/invites/$(inviteCode))
        && get(/databases/$(database)/documents/schools/$(schoolId)/invites/$(inviteCode)).data.active == true
        && get(/databases/$(database)/documents/schools/$(schoolId)/invites/$(inviteCode)).data.role == role;
    }

    function profileMatchesInvite(schoolId, inviteCode) {
      return validInvite(schoolId, inviteCode, request.resource.data.role)
        && request.resource.data.departmentIds is list
        && get(/databases/$(database)/documents/schools/$(schoolId)/invites/$(inviteCode)).data.departmentIds is list
        && request.resource.data.departmentIds == get(/databases/$(database)/documents/schools/$(schoolId)/invites/$(inviteCode)).data.departmentIds;
    }

    // Registration creates the user profile and any class membership in one
    // Firestore batch. getAfter() lets the membership rule validate the new
    // profile that will exist if the whole batch succeeds.
    function joiningProfileMatchesInvite(schoolId, inviteCode) {
      return existsAfter(/databases/$(database)/documents/users/$(request.auth.uid))
        && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId
        && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.inviteCode == inviteCode
        && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'pupil'
        && validInvite(
          schoolId,
          inviteCode,
          getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        );
    }

    function inviteCoversClass(schoolId, inviteCode, classId, subjectId) {
      return inviteCode is string
        && exists(/databases/$(database)/documents/schools/$(schoolId)/invites/$(inviteCode))
        && get(/databases/$(database)/documents/schools/$(schoolId)/invites/$(inviteCode)).data.active == true
        && get(/databases/$(database)/documents/schools/$(schoolId)/invites/$(inviteCode)).data.classIds is list
        && get(/databases/$(database)/documents/schools/$(schoolId)/invites/$(inviteCode)).data.classIds.hasAny([classId])
        && get(/databases/$(database)/documents/schools/$(schoolId)/invites/$(inviteCode)).data.subjectId == subjectId;
    }

    function approvedTransfer(transferId, pupilId, toSchoolId) {
      return transferId is string
        && exists(/databases/$(database)/documents/transferRequests/$(transferId))
        && get(/databases/$(database)/documents/transferRequests/$(transferId)).data.pupilId == pupilId
        && get(/databases/$(database)/documents/transferRequests/$(transferId)).data.toSchoolId == toSchoolId
        && get(/databases/$(database)/documents/transferRequests/$(transferId)).data.status == 'accepted';
    }

    match /users/{uid} {
      allow create: if isSelf(uid)
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.schoolId is string
        && request.resource.data.role in ['schoolAdmin', 'departmentHead', 'teacher', 'pupil']
        && profileMatchesInvite(
          request.resource.data.schoolId,
          request.resource.data.inviteCode
        );

      allow read: if isSelf(uid)
        || (hasUser() && me().role in ['schoolAdmin', 'departmentHead', 'teacher']
          && resource.data.schoolId == me().schoolId);

      allow update: if (
        isSelf(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName', 'email', 'photoURL', 'preferences', 'lastSeenAt', 'updatedAt'
        ])
      ) || (
        isSelf(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'schoolId', 'schoolHistoryIds', 'approvedTransferId', 'updatedAt'
        ])
        && approvedTransfer(
          request.resource.data.approvedTransferId,
          uid,
          request.resource.data.schoolId
        )
      ) || isSchoolAdmin(resource.data.schoolId);

      allow delete: if isSchoolAdmin(resource.data.schoolId);
    }

    match /schools/{schoolId} {
      allow get: if signedIn();
      allow list: if hasUser() && me().role == 'schoolAdmin';
      allow create: if false; // Create the first school document in Firebase Console.
      allow update: if isSchoolAdmin(schoolId);
      allow delete: if false;

      match /departments/{departmentId} {
        allow read: if canReadSchool(schoolId);
        allow write: if isSchoolAdmin(schoolId) || isDepartmentHead(schoolId);
      }

      match /subjects/{subjectId} {
        allow read: if canReadSchool(schoolId);
        allow write: if isSchoolAdmin(schoolId) || isDepartmentHead(schoolId);
      }

      match /classes/{classId} {
        allow read: if canReadSchool(schoolId);
        allow create: if isStaff(schoolId);
        allow update: if isStaff(schoolId);
        allow delete: if isSchoolAdmin(schoolId);
      }

      match /memberships/{membershipId} {
        allow read: if isStaff(schoolId)
          || (signedIn() && resource.data.userId == request.auth.uid);

        allow create: if isStaff(schoolId)
          || (
            signedIn()
            && request.resource.data.userId == request.auth.uid
            && joiningProfileMatchesInvite(schoolId, request.resource.data.inviteCode)
            && inviteCoversClass(
              schoolId,
              request.resource.data.inviteCode,
              request.resource.data.classId,
              request.resource.data.subjectId
            )
          )
          || (
            signedIn()
            && request.resource.data.userId == request.auth.uid
            && approvedTransfer(
              request.resource.data.approvedTransferId,
              request.auth.uid,
              schoolId
            )
          );

        allow update, delete: if isStaff(schoolId);
      }

      match /assessments/{assessmentId} {
        allow read: if isStaff(schoolId) || ownsPupilRecord(resource.data);

        allow create: if isStaff(schoolId)
          || (isCurrentSchool(schoolId)
            && me().role == 'pupil'
            && request.resource.data.pupilId == request.auth.uid
            && request.resource.data.entrySource == 'pupil'
            && request.resource.data.verificationStatus == 'selfEntered');

        allow update: if isStaff(schoolId)
          || (ownsPupilRecord(resource.data)
            && resource.data.entrySource == 'pupil'
            && request.resource.data.pupilId == request.auth.uid
            && request.resource.data.classId == resource.data.classId
            && request.resource.data.subjectId == resource.data.subjectId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'name', 'topic', 'date', 'score', 'maxScore', 'percentage', 'grade',
              'entrySource', 'verificationStatus', 'feedbackRecordId', 'updatedAt'
            ]));

        allow delete: if isStaff(schoolId);
      }

      match /feedbackRecords/{feedbackId} {
        allow read: if isStaff(schoolId) || ownsPupilRecord(resource.data);

        allow create: if isStaff(schoolId)
          || (isCurrentSchool(schoolId)
            && me().role == 'pupil'
            && request.resource.data.pupilId == request.auth.uid
            && request.resource.data.entrySource == 'pupil'
            && request.resource.data.verificationStatus == 'selfEntered'
            && request.resource.data.status in ['draft', 'open']);

        allow update: if isStaff(schoolId)
          || (ownsPupilRecord(resource.data)
            && resource.data.entrySource == 'pupil'
            && request.resource.data.pupilId == request.auth.uid
            && request.resource.data.classId == resource.data.classId
            && request.resource.data.subjectId == resource.data.subjectId
            && request.resource.data.status in ['draft', 'open', 'awaitingReview']
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'teacherId', 'feedbackType', 'assessmentName', 'assessmentComponent',
              'date', 'skill', 'score', 'maxScore', 'percentage', 'grade',
              'strength', 'strengthHtml', 'nextStep', 'nextStepHtml',
              'trafficLight', 'pupilNote', 'entrySource', 'verificationStatus',
              'status', 'submissionStatus', 'autosavedAt', 'submittedAt',
              'assessmentId', 'updatedAt'
            ]))
          || (ownsPupilRecord(resource.data)
            && request.resource.data.pupilId == request.auth.uid
            && request.resource.data.classId == resource.data.classId
            && request.resource.data.subjectId == resource.data.subjectId
            && request.resource.data.status in ['open', 'awaitingReview']
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'updatedAt'
            ]));

        allow delete: if isStaff(schoolId);
      }

      match /feedbackActions/{actionId} {
        allow read: if isStaff(schoolId) || ownsPupilRecord(resource.data);
        allow create: if isStaff(schoolId)
          || (signedIn()
            && request.resource.data.pupilId == request.auth.uid
            && request.resource.data.status == 'submitted');
        allow update: if isStaff(schoolId)
          || (ownsPupilRecord(resource.data)
            && request.resource.data.pupilId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'reflection', 'actionTaken', 'confidenceBefore', 'confidenceAfter',
              'status', 'submittedAt', 'updatedAt'
            ]));
        allow delete: if isSchoolAdmin(schoolId);
      }

      match /interventions/{interventionId} {
        allow read, write: if isStaff(schoolId);
      }

      match /invites/{inviteCode} {
        // A long random code can be checked directly during registration.
        // Creators can list only their own codes; the school administrator can
        // see all codes in the school.
        allow get: if true;
        allow list: if isSchoolAdmin(schoolId)
          || (hasUser() && resource.data.createdBy == request.auth.uid);

        // School administrators create department-head codes.
        // Department heads create teacher codes for departments they lead.
        // Teachers create pupil codes only for classes they teach.
        allow create: if (
          isSchoolAdmin(schoolId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.role == 'departmentHead'
          && request.resource.data.scopeType == 'department'
          && request.resource.data.departmentIds is list
          && request.resource.data.departmentIds.size() == 1
          && exists(/databases/$(database)/documents/schools/$(schoolId)/departments/$(request.resource.data.departmentIds[0]))
          && request.resource.data.classIds is list
          && request.resource.data.classIds.size() == 0
        ) || (
          isDepartmentHead(schoolId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.role == 'teacher'
          && request.resource.data.scopeType == 'department'
          && request.resource.data.departmentIds is list
          && request.resource.data.departmentIds.size() == 1
          && me().departmentIds.hasAny(request.resource.data.departmentIds)
          && exists(/databases/$(database)/documents/schools/$(schoolId)/departments/$(request.resource.data.departmentIds[0]))
          && request.resource.data.classIds is list
          && request.resource.data.classIds.size() == 0
        ) || (
          isTeacher(schoolId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.role == 'pupil'
          && request.resource.data.scopeType == 'class'
          && request.resource.data.classIds is list
          && request.resource.data.classIds.size() == 1
          && teachesClass(schoolId, request.resource.data.classIds[0])
          && request.resource.data.departmentIds is list
          && request.resource.data.departmentIds.size() == 1
          && request.resource.data.departmentIds[0] == get(/databases/$(database)/documents/schools/$(schoolId)/classes/$(request.resource.data.classIds[0])).data.departmentId
          && request.resource.data.subjectId == get(/databases/$(database)/documents/schools/$(schoolId)/classes/$(request.resource.data.classIds[0])).data.subjectId
        );

        allow update: if isSchoolAdmin(schoolId)
          || (isStaff(schoolId)
            && resource.data.createdBy == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'active', 'label', 'updatedAt'
            ]));
        allow delete: if isSchoolAdmin(schoolId)
          || (isStaff(schoolId) && resource.data.createdBy == request.auth.uid);
      }

      match /auditLogs/{logId} {
        allow read: if isSchoolAdmin(schoolId);
        allow create: if isStaff(schoolId);
        allow update, delete: if false;
      }
    }

    match /emailChangeRequests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.pupilId == request.auth.uid
        && request.resource.data.schoolId == me().schoolId
        && me().role == 'pupil'
        && request.resource.data.status == 'requested';

      allow read: if signedIn()
        && (resource.data.pupilId == request.auth.uid
          || isSchoolAdmin(resource.data.schoolId));

      allow update: if isSchoolAdmin(resource.data.schoolId)
        || (
          signedIn()
          && resource.data.pupilId == request.auth.uid
          && resource.data.status == 'approved'
          && request.auth.token.email == resource.data.newEmail
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'completedAt'
          ])
        );

      allow delete: if false;
    }

    match /transferRequests/{requestId} {
      allow create: if signedIn()
        && me().role == 'pupil'
        && request.resource.data.pupilId == request.auth.uid
        && request.resource.data.fromSchoolId == me().schoolId
        && request.resource.data.status == 'requested'
        && exists(/databases/$(database)/documents/schools/$(request.resource.data.toSchoolId))
        && get(/databases/$(database)/documents/schools/$(request.resource.data.toSchoolId)).data.transferCode
          == request.resource.data.destinationCode;

      allow read: if signedIn()
        && (resource.data.pupilId == request.auth.uid
          || isSchoolAdmin(resource.data.fromSchoolId)
          || isSchoolAdmin(resource.data.toSchoolId));

      allow update: if (
        isSchoolAdmin(resource.data.toSchoolId)
        && resource.data.status == 'requested'
        && request.resource.data.status in ['accepted', 'declined']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'classIds', 'decidedAt'
        ])
      ) || (
        signedIn()
        && resource.data.pupilId == request.auth.uid
        && resource.data.status == 'accepted'
        && request.resource.data.status == 'completed'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'completedAt'
        ])
      );

      allow delete: if false;
    }
  }
}
